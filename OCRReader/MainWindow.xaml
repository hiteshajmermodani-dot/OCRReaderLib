<Window x:Class="OCRReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OCRReader"
        mc:Ignorable="d"
        Title="OCR Text Reader" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisConverter"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#F44336"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OptionGroupBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#2196F3">
            <StackPanel Orientation="Vertical" Margin="20">
                <TextBlock Text="OCR Text Reader" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                <TextBlock Text="Import an image to extract text using OCR technology" FontSize="12" Foreground="#E3F2FD"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Image Display and Settings -->
            <Grid Grid.Column="0" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="*"/>
                    <!-- Image Preview -->
                    <RowDefinition Height="Auto"/>
                    <!-- Settings -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Image Preview Title -->
                <TextBlock Grid.Row="0" Text="Image Preview" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                <!-- Image Preview Area - Fills Available Space -->
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" 
                       Background="White" Margin="0,0,0,15">
                    <Grid>
                        <!-- Image Display -->
                        <Image Source="{Binding SelectedImage}" 
                               Stretch="Uniform"
                               Margin="10"/>

                        <!-- Empty State -->
                        <TextBlock Text="📁 No image selected" 
                                  FontSize="14" 
                                  Foreground="#999"
                                  VerticalAlignment="Center" 
                                  HorizontalAlignment="Center"
                                  Visibility="{Binding SelectedImage, Converter={StaticResource NullToVisConverter}}"/>
                    </Grid>
                </Border>

                <!-- Extraction Mode Options -->
                <Border Grid.Row="2" Style="{StaticResource OptionGroupBorderStyle}" Margin="0,0,0,15">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Extraction Mode" FontSize="12" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8"/>

                        <RadioButton GroupName="ExtractionMode" 
                                    Style="{StaticResource RadioButtonStyle}"
                                    IsChecked="{Binding IsPlainTextMode, Mode=TwoWay}"
                                    Content="📄 Plain Text"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                        <RadioButton GroupName="ExtractionMode" 
                                    Style="{StaticResource RadioButtonStyle}"
                                    IsChecked="{Binding IsTableMode, Mode=TwoWay}"
                                    Content="📊 Table"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                        <RadioButton GroupName="ExtractionMode" 
                                    Style="{StaticResource RadioButtonStyle}"
                                    IsChecked="{Binding IsAutoMode, Mode=TwoWay}"
                                    Content="🤖 Auto"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>

                        <TextBlock Text="Choose the format for text extraction. Plain Text extracts continuous text, Table mode organizes content in a structured grid format, and Auto detects the best format automatically." 
                                  FontSize="10" 
                                  Foreground="#666" 
                                  Margin="0,8,0,0"
                                  TextWrapping="Wrap"
                                  IsHitTestVisible="False"/>
                    </StackPanel>
                </Border>

                <!-- Control Buttons -->
                <StackPanel Grid.Row="3" Orientation="Vertical">
                    <Button Content="📥 Import Image" 
                           Style="{StaticResource PrimaryButtonStyle}"
                           Command="{Binding ImportImageCommand}"
                           IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                           Margin="0,0,0,10"
                           Padding="16,12"
                           FontSize="13"
                           Height="42"/>

                    <Button Content="🗑️ Clear All" 
                           Style="{StaticResource SecondaryButtonStyle}"
                           Command="{Binding ClearCommand}"
                           IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                           Padding="16,12"
                           FontSize="13"
                           Height="42"/>
                </StackPanel>
            </Grid>

            <!-- Right Panel: Text Display -->
            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="*"/>
                    <!-- Text Display -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Extracted Text Title -->
                <TextBlock Grid.Row="0" Text="Extracted Text" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                <!-- Text / Table Display Area - Fills Available Space -->
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" 
                        Background="White" Margin="0,0,0,15">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Text="{Binding ExtractedText, Mode=OneWay}"
                                 Visibility="{Binding ShowTextAboveTable, Converter={StaticResource BoolToVisConverter}}"
                                 Foreground="#333"
                                 Background="#FAFAFA"
                                 Padding="10"
                                 Margin="0,0,0,8"
                                 FontFamily="Segoe UI"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 MinHeight="70"
                                 MaxHeight="170"/>

                        <TextBox Grid.Row="0"
                                 Grid.RowSpan="2"
                                 Text="{Binding ExtractedText, Mode=OneWay}"
                                 Visibility="{Binding ShowPlainTextOnly, Converter={StaticResource BoolToVisConverter}}"
                                 Foreground="#333"
                                 Background="#FAFAFA"
                                 Padding="10"
                                 FontFamily="Segoe UI"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>

                        <DataGrid Grid.Row="1"
                                   ItemsSource="{Binding TablePreview}"
                                   Visibility="{Binding HasTableData, Converter={StaticResource BoolToVisConverter}}"
                                   AutoGenerateColumns="True"
                                   CanUserAddRows="False"
                                   CanUserDeleteRows="False"
                                   CanUserSortColumns="False"
                                   IsReadOnly="True"
                                   HeadersVisibility="Column"
                                   RowHeaderWidth="0"
                                   GridLinesVisibility="All"
                                   VerticalGridLinesBrush="#D0D0D0"
                                   HorizontalGridLinesBrush="#D0D0D0"/>
                    </Grid>
                </Border>

                <!-- Actions -->
                <Button Grid.Row="2"
                       Content="📋 Copy to Clipboard" 
                       Style="{StaticResource PrimaryButtonStyle}"
                       Command="{Binding CopyTextCommand}"
                       IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                       Padding="16,12"
                       FontSize="13"
                       Height="42"/>
            </Grid>
        </Grid>

        <!-- Footer Status Bar -->
        <StatusBar Grid.Row="2" Background="#F5F5F5" Padding="10">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#555" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="100" Height="4" IsIndeterminate="True" 
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisConverter}}"
                            Foreground="#2196F3"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
